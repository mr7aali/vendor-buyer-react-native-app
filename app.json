{
  "expo": {
    "jsEngine": "hermes",
    "name": "LinkooTo",
    "slug": "link-to",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "yozietranceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "developmentClient": {
      "silentLaunch": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soriful420.yozietranceapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow LinkooTo to take product and chat photos with your camera.",
        "NSPhotoLibraryUsageDescription": "Allow LinkooTo to choose product and chat photos from your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.soriful420.yozietranceApp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LinkooTo to access your photos so you can upload product and chat images.",
          "cameraPermission": "Allow LinkooTo to use your camera so you can capture product and chat images."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "color": "#278687"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow LinkooTo to use biometrics for secure sign in."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow LinkooTo to securely access your saved login details."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.yozietranceapp",
          "enableGooglePay": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/imagelogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b80bbe7-3d1a-4611-ba23-9c81db657275"
      }
    }
  }
}
